generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MonitorState {
  UNKNOWN
  UP
  DOWN
  PAUSED
}

enum IncidentStatus {
  OPEN
  RESOLVED
}

enum NotificationType {
  DOWN
  RECOVERED
  SSL_EXPIRING
  MANUAL_CHECK
  DAILY_SUMMARY
  WEEKLY_SUMMARY
}

enum MonitorTermKind {
  TRIAL
  SUBSCRIPTION
}

enum UserSubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum SubscriptionCheckoutStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
}

enum FunnelSessionKind {
  ADD_MONITOR
}

enum FunnelSessionStatus {
  ACTIVE
  COMPLETED
  STOPPED
  ABANDONED
}

enum AccessReminderKind {
  TRIAL
  SUBSCRIPTION
}

model User {
  id                   String    @id @default(cuid())
  telegramId           String    @unique
  username             String?
  firstName            String?
  timezone             String    @default("Europe/Moscow")
  dailySummaryEnabled  Boolean   @default(false)
  dailySummaryTimeMinutes Int?
  dailySummaryLastSentAt DateTime?
  dailySummaryPromptedAt DateTime?
  weeklySummaryEnabled Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  monitors             Monitor[]
  subscription         UserSubscription?
  subscriptionCheckouts SubscriptionCheckout[]
  subscriptionPayments SubscriptionPayment[]
  funnelSessions       FunnelSession[]
  funnelEvents         FunnelEvent[]
  accessReminders      AccessReminderLog[]

  @@index([createdAt])
  @@index([dailySummaryEnabled, dailySummaryTimeMinutes])
}

model Monitor {
  id                  String            @id @default(cuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  url                 String
  normalizedUrl       String
  isActive            Boolean           @default(true)
  intervalMinutes     Int
  timeoutMs           Int               @default(5000)
  consecutiveFailures Int               @default(0)
  failureThreshold    Int               @default(3)
  recoveryThreshold   Int               @default(1)
  currentState        MonitorState      @default(UNKNOWN)
  lastCheckedAt       DateTime?
  lastStatusCode      Int?
  lastResponseTimeMs  Int?
  lastErrorMessage    String?
  requiredText        String?
  checkSsl            Boolean           @default(false)
  checkJson           Boolean           @default(false)
  jsonRules           Json?
  termKind            MonitorTermKind   @default(TRIAL)
  endsAt              DateTime?
  billingLocked       Boolean           @default(false)
  deletedAt           DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  checkResults        CheckResult[]
  incidents           Incident[]
  sslAlerts           SslAlertLog[]
  notifications       NotificationLog[]
  accessReminders     AccessReminderLog[]

  @@index([userId, isActive, deletedAt])
  @@index([currentState, isActive])
  @@index([normalizedUrl])
}

model UserSubscription {
  id                        String                 @id @default(cuid())
  userId                    String                 @unique
  user                      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                    UserSubscriptionStatus @default(ACTIVE)
  planKey                   String
  amountStars               Int
  currentPeriodStart        DateTime
  currentPeriodEnd          DateTime
  cancelAtPeriodEnd         Boolean                @default(false)
  canceledAt                DateTime?
  lastPaymentAt             DateTime?
  lastInvoicePayload        String?
  lastTelegramPaymentChargeId String?
  lastProviderPaymentChargeId String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  payments                  SubscriptionPayment[]
  accessReminders           AccessReminderLog[]

  @@index([status, currentPeriodEnd(sort: Desc)])
}

model SubscriptionCheckout {
  id                       String                     @id @default(cuid())
  userId                   String
  user                     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  funnelSessionId          String?
  funnelSession            FunnelSession?             @relation(fields: [funnelSessionId], references: [id], onDelete: SetNull)
  chatId                   String
  invoicePayload           String                     @unique
  status                   SubscriptionCheckoutStatus @default(PENDING)
  planKey                  String
  amountStars              Int
  monitorDraft             Json?
  createdMonitorId         String?
  paidAt                   DateTime?
  expiresAt                DateTime?
  telegramPaymentChargeId  String?
  providerPaymentChargeId  String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([funnelSessionId, createdAt(sort: Desc)])
}

model SubscriptionPayment {
  id                        String            @id @default(cuid())
  userId                    String
  user                      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userSubscriptionId        String?
  userSubscription          UserSubscription? @relation(fields: [userSubscriptionId], references: [id], onDelete: SetNull)
  invoicePayload            String
  currency                  String
  amountStars               Int
  telegramPaymentChargeId   String            @unique
  providerPaymentChargeId   String?
  isRecurring               Boolean           @default(false)
  isFirstRecurring          Boolean           @default(false)
  subscriptionExpiresAt     DateTime?
  createdMonitorId          String?
  createdAt                 DateTime          @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([invoicePayload, createdAt(sort: Desc)])
}

model CheckResult {
  id             String   @id @default(cuid())
  monitorId      String
  monitor        Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  success        Boolean
  statusCode     Int?
  responseTimeMs Int?
  errorMessage   String?
  contentMatched Boolean?
  jsonMatched    Boolean?
  checkedAt      DateTime @default(now())

  @@index([monitorId, checkedAt(sort: Desc)])
  @@index([success, checkedAt])
}

model Incident {
  id                  String         @id @default(cuid())
  monitorId           String
  monitor             Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  startedAt           DateTime
  resolvedAt          DateTime?
  durationSeconds     Int?
  reason              String
  status              IncidentStatus
  openedAfterFailures Int            @default(3)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([monitorId, status, startedAt(sort: Desc)])
  @@index([status, startedAt(sort: Desc)])
}

model SslAlertLog {
  id            String   @id @default(cuid())
  monitorId     String
  monitor       Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  thresholdDays Int
  expiresAt     DateTime
  sentAt        DateTime @default(now())

  @@unique([monitorId, thresholdDays, expiresAt])
  @@index([monitorId, sentAt(sort: Desc)])
}

model NotificationLog {
  id        String           @id @default(cuid())
  monitorId String
  monitor   Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  type      NotificationType
  payload   Json
  sentAt    DateTime         @default(now())

  @@index([monitorId, type, sentAt(sort: Desc)])
}

model FunnelSession {
  id               String              @id @default(cuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind             FunnelSessionKind
  status           FunnelSessionStatus @default(ACTIVE)
  currentStepKey   String
  currentStepLabel String
  lastEventPayload Json?
  startedAt        DateTime            @default(now())
  lastEventAt      DateTime            @default(now())
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  events           FunnelEvent[]
  checkouts        SubscriptionCheckout[]

  @@index([userId, kind, status, lastEventAt(sort: Desc)])
  @@index([status, lastEventAt(sort: Desc)])
}

model FunnelEvent {
  id        String        @id @default(cuid())
  sessionId String
  session   FunnelSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepKey   String
  stepLabel String
  payload   Json?
  createdAt DateTime      @default(now())

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([userId, stepKey, createdAt(sort: Desc)])
}

model AccessReminderLog {
  id                 String            @id @default(cuid())
  kind               AccessReminderKind
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  monitorId          String?
  monitor            Monitor?          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  userSubscriptionId String?
  userSubscription   UserSubscription? @relation(fields: [userSubscriptionId], references: [id], onDelete: Cascade)
  thresholdDays      Int
  targetEndsAt       DateTime
  sentAt             DateTime          @default(now())

  @@index([kind, userId, thresholdDays, sentAt(sort: Desc)])
  @@index([monitorId, sentAt(sort: Desc)])
  @@index([userSubscriptionId, sentAt(sort: Desc)])
}
