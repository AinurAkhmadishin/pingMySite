NODE_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
BOT_TOKEN=your-telegram-bot-token
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ping_my_site_bot?schema=public
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_TIMEOUT_MS=5000
MAX_REDIRECTS=5
MAX_RESPONSE_BODY_BYTES=1048576
MONITOR_USER_AGENT=PingMySiteBot/1.0
BOT_POLLING=true
CHECK_RETRY_COUNT=1
CHECK_RETRY_DELAY_MS=300
CHECK_LOCK_TTL_SECONDS=60
MONITOR_WORKER_CONCURRENCY=10
INCIDENT_WORKER_CONCURRENCY=5
SSL_WORKER_CONCURRENCY=5
SUMMARY_WORKER_CONCURRENCY=2
ENABLE_DAILY_SUMMARIES=false
ENABLE_WEEKLY_SUMMARIES=false
MANUAL_CHECK_RATE_LIMIT_SECONDS=15
